# Avenseal environment template.
# Copy this file to .env.local for local development. Use placeholder values only.

# Application
# Public base URL used for appointment links and redirects. Required for deployed environments.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default tenant for the Avenseal operating business. Optional; defaults to "avenseal".
DEFAULT_ORGANIZATION_SLUG=avenseal

# Admin session signing secret. Required in production; use a long random value.
ADMIN_SESSION_SECRET=replace-with-long-random-secret-at-least-32-characters

# Development fallback admin credentials. Used only when Supabase service config is absent.
# For staging integration tests, set these in ignored environment configuration.
ADMIN_DEMO_EMAIL=
ADMIN_DEMO_PASSWORD=

# Public Supabase browser-safe configuration. Required when using Supabase-backed auth.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase server-only service role key. Required for Supabase-backed server workflows.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Public booking rate limit. Optional; defaults are 60000 ms and 8 requests.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=8

# Stripe payment integration. Optional; leave blank to disable live Checkout creation.
# Keep both values server-side only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Calendar integration placeholders. Optional; not required for core CI.
# Keep client secret and access token server-side only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/admin/integrations/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=
GOOGLE_CALENDAR_ID=
# Deprecated fallback for pre-OAuth development only. Prefer organization-scoped OAuth connections.
GOOGLE_CALENDAR_ACCESS_TOKEN=

# Gmail SMTP email delivery. Optional; incomplete configuration skips sending.
# Use a Google App Password for SMTP_PASSWORD, never the account password.
EMAIL_FROM="Avenseal Appointments <appointments@avenseal.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=appointments@avenseal.com
SMTP_PASSWORD=
# In staging, only these comma-separated recipients may receive communications.
COMMUNICATION_SAFE_RECIPIENTS=
COMMUNICATION_PROCESSOR_SECRET=
COMMUNICATION_PROCESSOR_BATCH_SIZE=10
COMMUNICATION_PROCESSING_TIMEOUT_MINUTES=10

# Testing and E2E helpers. Optional; used by Playwright or live integration tests.
# Required for live Supabase integration tests when Supabase credentials are present.
# Use "staging" only after confirming the target is not production.
LIVE_SUPABASE_ENVIRONMENT=
STAGING_STAFF_DEMO_EMAIL=
STAGING_STAFF_DEMO_PASSWORD=
E2E_PORT=3000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
E2E_SKIP_WEB_SERVER=
